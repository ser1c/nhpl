---
import '../styles/global.css';
import { getLangFromUrl, t } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
}

const lang = getLangFromUrl(Astro.url);
const { title, description } = Astro.props;
const siteName = t(lang, 'site.name');
const pageTitle = title ? `${title} | ${siteName}` : siteName;
const pageDescription = description ?? t(lang, 'site.tagline');
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <meta name="theme-color" content="#1A6B6B" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+Devanagari:wght@400;500;700&display=swap" rel="stylesheet" />
    <title>{pageTitle}</title>
  </head>
  <body class="min-h-screen flex flex-col bg-surface text-gray-dark font-sans antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:bg-teal focus:text-white focus:px-4 focus:py-2 focus:rounded focus:z-50">
      {lang === 'ne' ? 'मुख्य सामग्रीमा जानुहोस्' : 'Skip to main content'}
    </a>
    <slot />
  </body>
</html>
