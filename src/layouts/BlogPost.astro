---
import Base from './Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, t } from '../i18n/utils';

interface Props {
  title: string;
  author: string;
  date: Date;
  tags?: string[];
}

const lang = getLangFromUrl(Astro.url);
const { title, author, date, tags } = Astro.props;
const formattedDate = date.toLocaleDateString(lang === 'ne' ? 'ne-NP' : 'en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title={title}>
  <Header />
  <main class="flex-1 max-w-3xl mx-auto px-4 py-8 w-full">
    <article>
      <header class="mb-8">
        <h1 class="text-3xl font-bold text-gray-dark mb-3">{title}</h1>
        <div class="text-sm text-gray-mid">
          {t(lang, 'blog.by')} <span class="font-medium text-teal">{author}</span>
          <span class="mx-2">&middot;</span>
          <time datetime={date.toISOString()}>{formattedDate}</time>
        </div>
        {tags && tags.length > 0 && (
          <div class="flex gap-2 mt-3">
            {tags.map((tag) => (
              <span class="text-xs bg-teal-light text-teal px-2 py-1 rounded">{tag}</span>
            ))}
          </div>
        )}
      </header>
      <div class="prose prose-teal max-w-none">
        <slot />
      </div>
    </article>
  </main>
  <Footer />
</Base>
