---
import Page from '../layouts/Page.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
---

<Page>
  <section class="text-center py-12">
    <h1 class="text-4xl font-bold text-teal mb-4">Nepal Health Policy Lab</h1>
    <p class="text-lg text-gray-mid max-w-2xl mx-auto leading-relaxed">
      Building the evidence infrastructure for health policy in Nepal.
      We make rigorous global health research accessible and actionable
      for Nepal's policymakers, practitioners, and public.
    </p>
  </section>

  <section class="grid md:grid-cols-3 gap-6 py-8">
    <div class="bg-teal-light rounded-lg p-5">
      <h2 class="font-bold text-teal mb-2">Evidence Portal</h2>
      <p class="text-sm text-gray-mid">A searchable database of global health policy research, curated and contextualised for Nepal.</p>
    </div>
    <div class="bg-teal-light rounded-lg p-5">
      <h2 class="font-bold text-teal mb-2">Policy Digest</h2>
      <p class="text-sm text-gray-mid">A monthly summary of the most relevant new global health research for Nepal's policymakers.</p>
    </div>
    <div class="bg-teal-light rounded-lg p-5">
      <h2 class="font-bold text-teal mb-2">Research Blog</h2>
      <p class="text-sm text-gray-mid">Original insights and findings from our research, written in accessible language with named authors.</p>
    </div>
  </section>

  <div class="py-8">
    <NewsletterSignup />
  </div>
</Page>
