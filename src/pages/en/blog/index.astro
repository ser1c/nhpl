---
import Page from '../../../layouts/Page.astro';
import BlogCard from '../../../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import { t } from '../../../i18n/utils';

const lang = 'en' as const;
const posts = (await getCollection('blog', ({ data }) => data.lang === lang && !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Page title={t(lang, 'nav.blog')}>
  <h1 class="text-3xl font-bold text-teal mb-6">{t(lang, 'nav.blog')}</h1>

  {posts.length === 0 ? (
    <p class="text-gray-mid">{t(lang, 'blog.noPosts')}</p>
  ) : (
    <div class="grid gap-4">
      {posts.map((post) => (
        <BlogCard
          title={post.data.title}
          author={post.data.author}
          date={post.data.date}
          slug={post.id.replace('en/', '')}
          tags={post.data.tags}
        />
      ))}
    </div>
  )}
</Page>
