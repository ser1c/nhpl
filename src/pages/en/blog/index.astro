---
import Page from '../../../layouts/Page.astro';
import BlogCard from '../../../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import { t } from '../../../i18n/utils';

const lang = 'en' as const;
const posts = (await getCollection('blog', ({ data }) => data.lang === lang && !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Page title={t(lang, 'nav.blog')}>
  <section class="mb-10">
    <p class="text-xs uppercase tracking-widest text-teal font-semibold mb-3">Research Blog</p>
    <h1 class="text-3xl md:text-4xl font-bold text-gray-dark tracking-tight mb-3">{t(lang, 'nav.blog')}</h1>
    <p class="text-lg text-gray-mid">Original analysis and commentary from our team on health policy evidence relevant to Nepal.</p>
  </section>

  {posts.length === 0 ? (
    <div class="text-center py-20 bg-surface-alt rounded-2xl">
      <p class="text-gray-dark font-semibold text-lg mb-2">Our first articles are in preparation</p>
      <p class="text-sm text-gray-mid max-w-sm mx-auto mb-4">
        Subscribe to be notified when they publish, or explore our Evidence Portal for curated health research.
      </p>
      <a href="/en/evidence" class="inline-block bg-teal text-white px-6 py-2.5 rounded-lg text-sm font-medium hover:bg-teal-dark transition-colors">
        Explore Evidence
      </a>
    </div>
  ) : (
    <div class="grid gap-4">
      {posts.map((post) => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          author={post.data.author}
          date={post.data.date}
          slug={post.id.replace('en/', '')}
          tags={post.data.tags}
        />
      ))}
    </div>
  )}
</Page>
