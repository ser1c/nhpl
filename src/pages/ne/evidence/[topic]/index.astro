---
import Page from '../../../../layouts/Page.astro';
import EvidenceSearch from '../../../../components/EvidenceSearch';
import { getTopics, getEvidenceByTopic } from '../../../../data/evidence-loader';
import { t } from '../../../../i18n/utils';
import type { GetStaticPaths } from 'astro';

const lang = 'ne';

export const getStaticPaths: GetStaticPaths = () => {
  const topics = getTopics();
  return topics.map((topic) => ({
    params: { topic: topic.slug },
    props: { topic },
  }));
};

const { topic } = Astro.props;
const papers = getEvidenceByTopic(topic.slug);
---

<Page title={topic.title[lang]}>
  <div class="mb-6">
    <a href={`/${lang}/evidence`} class="text-sm text-teal hover:text-teal-dark transition-colors">
      &larr; {t(lang, 'evidence.backToPortal')}
    </a>
  </div>

  <!-- Topic Header -->
  <header class="mb-8">
    <div class="flex items-center gap-3 mb-3">
      <span class="text-3xl">{topic.icon}</span>
      <h1 class="text-2xl font-bold text-gray-dark">{topic.title[lang]}</h1>
    </div>
    <p class="text-gray-mid leading-relaxed">{topic.overview[lang]}</p>
  </header>

  <!-- Key Questions -->
  <section class="bg-teal-light rounded-lg p-6 mb-8">
    <h2 class="font-bold text-teal mb-3">{t(lang, 'evidence.keyQuestions')}</h2>
    <ul class="space-y-2">
      {topic.keyQuestions[lang].map((q) => (
        <li class="text-sm text-gray-dark flex items-start gap-2">
          <span class="text-teal mt-0.5">?</span>
          {q}
        </li>
      ))}
    </ul>
  </section>

  <!-- Papers -->
  <section>
    <h2 class="text-lg font-bold text-gray-dark mb-4">
      {papers.length} {t(lang, 'evidence.papers')}
    </h2>

    <noscript>
      <div class="space-y-4">
        {papers.map((paper) => (
          <div class="border border-gray-200 rounded-lg p-4">
            <h3 class="font-bold text-sm">{paper.title}</h3>
            <p class="text-xs text-gray-500 mt-1">{paper.authors.join(', ')} &middot; {paper.year}</p>
            <a href={`/${lang}/evidence/${topic.slug}/${paper.slug}`} class="text-xs text-teal mt-2 inline-block">
              {t(lang, 'blog.readMore')} &rarr;
            </a>
          </div>
        ))}
      </div>
    </noscript>

    <EvidenceSearch
      client:load
      papers={papers}
      lang={lang}
      basePath={`/${lang}/evidence`}
      topicSlug={topic.slug}
    />
  </section>
</Page>
