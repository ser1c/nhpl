---
import Page from '../../layouts/Page.astro';
import TeamMember from '../../components/TeamMember.astro';
import { t } from '../../i18n/utils';

const lang = 'ne' as const;
---

<Page title={t(lang, 'nav.about')}>
  <!-- Mission hero -->
  <section class="bg-teal-light rounded-2xl p-8 md:p-12 mb-12">
    <p class="text-xs uppercase tracking-widest text-teal font-semibold mb-3">हाम्रो लक्ष्य</p>
    <h1 class="text-3xl md:text-4xl font-bold text-gray-dark tracking-tight mb-4">{t(lang, 'site.name')} बारे</h1>
    <p class="text-lg text-gray-mid leading-relaxed max-w-3xl">
      नेपालका स्वास्थ्य नीति निर्माताहरू, अभ्यासकर्ताहरू र जनताको लागि कडा प्रमाणलाई पहुँचयोग्य र कार्ययोग्य बनाउन समर्पित स्वास्थ्य नीति अनुसन्धान पहल।
    </p>
  </section>

  <div class="max-w-3xl mb-12">
    <p class="text-gray-mid leading-7 mb-4">
      हामी विशेष रूपमा स्वास्थ्यमा केन्द्रित छौं। विस्तृत भन्दा गहिरो गएर, हामी
      नेपालमा स्वास्थ्य नीति प्रमाणको लागि निश्चित स्रोत बन्ने लक्ष्य राख्छौं। हाम्रो
      मुख्य काम <strong class="text-gray-dark">अनुवाद</strong> हो: हरेक वर्ष प्रकाशित हुने हजारौं उच्च-गुणस्तरका
      स्वास्थ्य अर्थशास्त्र अध्ययनहरूलाई संश्लेषण, सान्दर्भिकीकरण र पहुँचयोग्य बनाउने।
    </p>
  </div>

  <!-- Values -->
  <section class="grid md:grid-cols-3 gap-6 mb-14">
    <div class="bg-white border border-border rounded-xl p-6">
      <h3 class="font-semibold text-gray-dark mb-2">खुला पहुँच</h3>
      <p class="text-sm text-gray-mid leading-relaxed">हाम्रा सबै प्रमाण सारांश र उपकरणहरू निःशुल्क उपलब्ध छन्। ज्ञान पेवालको पछाडि हुनु हुँदैन।</p>
    </div>
    <div class="bg-white border border-border rounded-xl p-6">
      <h3 class="font-semibold text-gray-dark mb-2">कडा र पारदर्शी</h3>
      <p class="text-sm text-gray-mid leading-relaxed">हरेक पत्र गम्भीर रूपमा समीक्षा गरिन्छ। हाम्रा विधि र डाटा जाँचको लागि खुला छन्।</p>
    </div>
    <div class="bg-white border border-border rounded-xl p-6">
      <h3 class="font-semibold text-gray-dark mb-2">नेपाल-केन्द्रित</h3>
      <p class="text-sm text-gray-mid leading-relaxed">विश्वव्यापी अनुसन्धान सान्दर्भिक हुँदा मात्र मूल्यवान हुन्छ। हामी सधैं सोध्छौं: नेपालको लागि यसको अर्थ के हो?</p>
    </div>
  </section>

  <!-- Team -->
  <section class="mb-14">
    <h2 class="text-2xl font-bold text-gray-dark tracking-tight mb-6">टोली</h2>
    <div class="grid md:grid-cols-2 gap-4">
      <TeamMember
        name="सबिन सुवेदी"
        role="सह-संस्थापक"
        image="/team/sabin.jpg"
        bio="स्ट्र्याथक्लाइड विश्वविद्यालयमा अर्थशास्त्रमा पीएचडी उम्मेदवार, स्वास्थ्य अर्थशास्त्र र कारणात्मक अनुमानमा विशेषज्ञता। प्राविधिक अनुसन्धान एजेन्डा र AI-सहायता प्राप्त डाटाबेस निर्माणको नेतृत्व गर्दछन्।"
      />
      <TeamMember
        name="मुकेश अधिकारी"
        role="सह-संस्थापक"
        image="/team/mukesh.jpg"
        bio="UNC गिलिंग्स स्कुल अफ ग्लोबल पब्लिक हेल्थमा स्वास्थ्य नीति र व्यवस्थापनमा पीएचडी विद्यार्थी। प्रमाण संश्लेषण र सामग्री रणनीतिको सह-नेतृत्व गर्दछन्।"
      />
      <TeamMember
        name="प्रज्ज्वल ढुंगाना"
        role="क्षेत्र समन्वयक"
        bio="काठमाडौंमा आधारित, सरकारी सम्पर्क, परामर्श उपस्थिति, र जमिनमा संस्थागत सम्बन्ध व्यवस्थापनको लागि जिम्मेवार।"
      />
      <TeamMember
        name="सुरेश टिंकारी"
        role="सल्लाहकार"
        image="/team/suresh.jpg"
        bio="नेपालको स्वास्थ्य बीमा बोर्डमा आईटी प्रबन्धक। नेपालको स्वास्थ्य बीमा प्रणालीको संस्थागत ज्ञान प्रदान गर्दछन् र पहल र HIB बीच पुल बनाउँछन्।"
      />
    </div>
  </section>

  <!-- Affiliations -->
  <section class="text-center py-8 border-t border-border">
    <p class="text-sm text-gray-tertiary mb-2">संस्थागत सम्बन्ध</p>
    <p class="text-gray-mid font-medium">स्ट्र्याथक्लाइड विश्वविद्यालय &middot; UNC गिलिंग्स स्कुल अफ ग्लोबल पब्लिक हेल्थ</p>
  </section>
</Page>
