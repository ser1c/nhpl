---
import { getLangFromUrl, t, getLocalePath } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  author: string;
  date: Date;
  slug: string;
  tags?: string[];
}

const lang = getLangFromUrl(Astro.url);
const { title, description, author, date, slug, tags } = Astro.props;
const formattedDate = date.toLocaleDateString(lang === 'ne' ? 'ne-NP' : 'en-GB', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={getLocalePath(lang, `/blog/${slug}`)} class="block bg-white border border-border rounded-xl p-4 md:p-6 hover:shadow-md hover:border-teal transition-all group">
  <h3 class="font-semibold text-gray-dark group-hover:text-teal transition-colors text-lg leading-snug">{title}</h3>
  {description && (
    <p class="text-sm text-gray-mid mt-2 line-clamp-2 leading-relaxed">{description}</p>
  )}
  <div class="flex items-center gap-3 text-sm text-gray-tertiary mt-3">
    <span>{t(lang, 'blog.by')} <span class="font-medium text-gray-mid">{author}</span></span>
    <span>&middot;</span>
    <time datetime={date.toISOString()}>{formattedDate}</time>
  </div>
  {tags && tags.length > 0 && (
    <div class="flex gap-1.5 mt-3">
      {tags.map((tag) => (
        <span class="text-xs bg-surface-alt text-gray-mid px-2 py-0.5 rounded-md">{tag}</span>
      ))}
    </div>
  )}
</a>
