---
import { getLangFromUrl, t, getLocalePath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
---

<div class="text-center">
  <h2 class="text-2xl font-bold text-gray-dark tracking-tight mb-3">{t(lang, 'subscribe.heading')}</h2>
  <p class="text-sm text-gray-mid mb-6 max-w-md mx-auto leading-relaxed">{t(lang, 'subscribe.description')}</p>
  <a
    href={getLocalePath(lang, '/subscribe')}
    class="inline-block bg-amber text-white px-8 py-3 rounded-lg font-medium hover:bg-amber-dark transition-colors shadow-sm"
  >
    {t(lang, 'nav.subscribe')}
  </a>
  <p class="text-xs text-gray-tertiary mt-3">
    {lang === 'ne' ? 'निःशुल्क। महिनामा एक पटक भन्दा बढी कहिल्यै छैन।' : 'Free. Never more than once a month.'}
  </p>
</div>
