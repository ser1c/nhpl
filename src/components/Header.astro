---
import { getLangFromUrl, t, getLocalePath, getOtherLang } from '../i18n/utils';
import { languages } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const otherLang = getOtherLang(lang);

const navItems = [
  { key: 'nav.home' as const, path: '/' },
  { key: 'nav.evidence' as const, path: '/evidence' },
  { key: 'nav.about' as const, path: '/about' },
  { key: 'nav.blog' as const, path: '/blog' },
  { key: 'nav.digest' as const, path: '/digest' },
  { key: 'nav.subscribe' as const, path: '/subscribe' },
];

const currentPath = Astro.url.pathname.replace(`/${lang}`, '') || '/';
const otherLangPath = getLocalePath(otherLang, currentPath);

function isActive(itemPath: string): boolean {
  if (itemPath === '/') return currentPath === '/';
  return currentPath.startsWith(itemPath);
}
---

<header class="border-b border-border bg-white sticky top-0 z-40">
  <div class="max-w-6xl mx-auto px-4 md:px-8 py-5 flex items-center justify-between">
    <a href={getLocalePath(lang, '/')} class="group">
      <span class="text-xl font-bold text-teal group-hover:text-teal-dark transition-colors">
        {t(lang, 'site.name')}
      </span>
      <span class="hidden lg:block text-xs text-gray-tertiary mt-0.5">
        {lang === 'ne' ? 'स्वास्थ्य नीति अनुसन्धान' : 'Health Policy Research'}
      </span>
    </a>

    <div class="flex items-center gap-6">
      <nav class="hidden md:flex gap-6">
        {navItems.map((item) => (
          <a
            href={getLocalePath(lang, item.path)}
            class={`text-sm font-medium transition-colors ${
              isActive(item.path)
                ? 'text-teal border-b-2 border-teal pb-0.5'
                : 'text-gray-mid hover:text-teal'
            }`}
          >
            {t(lang, item.key)}
          </a>
        ))}
      </nav>

      <a
        href={otherLangPath}
        class="text-sm border border-teal text-teal px-2.5 py-1 rounded-lg hover:bg-teal hover:text-white transition-colors"
        aria-label={`Switch to ${languages[otherLang]}`}
      >
        {languages[otherLang]}
      </a>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-gray-mid hover:text-teal transition-colors"
        aria-label="Menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu panel -->
  <nav
    id="mobile-menu"
    class="md:hidden hidden border-t border-border bg-white"
  >
    <div class="px-4 py-3 space-y-1">
      {navItems.map((item) => (
        <a
          href={getLocalePath(lang, item.path)}
          class={`block py-3 text-base font-medium transition-colors ${
            isActive(item.path)
              ? 'text-teal border-l-3 border-teal pl-3'
              : 'text-gray-mid hover:text-teal pl-4'
          }`}
        >
          {t(lang, item.key)}
        </a>
      ))}
      <a
        href={otherLangPath}
        class="block py-3 text-base font-medium text-gray-mid hover:text-teal pl-4"
        aria-label={`Switch to ${languages[otherLang]}`}
      >
        {languages[otherLang]}
      </a>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    btn.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  }
</script>
